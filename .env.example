# .env.example — copiar a .env y completar

# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# PostgreSQL
# Si usas Docker Compose, el host es 'postgres'. Si es local, 'localhost'.
POSTGRES_URL=postgresql://engram_user:engram_password@postgres:5432/db_engram
POSTGRES_PASSWORD=engram_password

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=engram-index

# Gemini (embeddings + consultas RAG)
GEMINI_API_KEY=
